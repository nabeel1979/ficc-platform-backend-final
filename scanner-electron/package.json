{
  "name": "ficc-scanner",
  "version": "1.0.0",
  "description": "FICC Scanner - Professional Document Scanning & Upload",
  "main": "main.js",
  "homepage": "./",
  "author": "FICC Platform",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "dependencies": {
    "ws": "^8.13.0"
  },
  "devDependencies": {
    "electron": "^29.0.0",
    "electron-builder": "^24.6.4"
  },
  "build": {
    "appId": "com.ficc.scanner",
    "productName": "FICC Scanner",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "style.css",
      "script.js",
      "icon.ico",
      "package.json"
    ],
    "win": {
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FICC Scanner",
      "installerLanguages": ["ar"],
      "language": "1025"
    },
    "portable": {
      "artifactName": "FICC-Scanner-Portable.exe"
    }
  }
}
