# Database
DB_PASSWORD=your_sql_server_password

# JWT
JWT_SECRET=your_jwt_secret_min_32_chars_long

# Storage
STORAGE_PUBLIC_URL=https://your-storage-url.com

# Cloudflare R2
CLOUDFLARE_ACCOUNT_ID=your_account_id
CLOUDFLARE_ACCESS_KEY=your_access_key
CLOUDFLARE_SECRET_KEY=your_secret_key
CLOUDFLARE_PUBLIC_URL=https://pub-xxxxx.r2.dev

# R2 (Alternative)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY=your_access_key
R2_SECRET_KEY=your_secret_key
R2_PUBLIC_URL=https://pub-xxxxx.r2.dev

# Email (Zoho)
EMAIL_USERNAME=your_email@ficc.iq
EMAIL_PASSWORD=your_app_password
EMAIL_FROM=noreply@ficc.iq

# Twilio
TWILIO_ACCOUNT_SID=your_account_sid
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_VERIFY_SERVICE_SID=your_verify_service_sid

# ZeptoMail
ZEPTOMAIL_API_KEY=your_zeptomail_api_key

# Brevo
BREVO_API_KEY=your_brevo_api_key
