{
  "ConnectionStrings": {
    "DefaultConnection": "Server=ficc-sqlserver,1433;Database=FICCPlatform;User Id=sa;Password=${DB_PASSWORD};TrustServerCertificate=True;"
  },
  "JwtSettings": {
    "Secret": "${JWT_SECRET}",
    "Issuer": "FICCPlatform",
    "Audience": "FICCPlatformUsers",
    "ExpiryDays": 7
  },
  "Storage": {
    "UploadsPath": "/uploads",
    "PublicUrl": "${STORAGE_PUBLIC_URL}"
  },
  "Cloudflare": {
    "AccountId": "${CLOUDFLARE_ACCOUNT_ID}",
    "AccessKeyId": "${CLOUDFLARE_ACCESS_KEY}",
    "SecretKey": "${CLOUDFLARE_SECRET_KEY}",
    "Bucket": "ficcmedia",
    "PublicUrl": "${CLOUDFLARE_PUBLIC_URL}"
  },
  "R2": {
    "AccountId": "${R2_ACCOUNT_ID}",
    "AccessKeyId": "${R2_ACCESS_KEY}",
    "SecretKey": "${R2_SECRET_KEY}",
    "BucketName": "ficcmedia",
    "PublicUrl": "${R2_PUBLIC_URL}"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Cors": {
    "AllowedOrigins": [
      "https://ficc.iq",
      "https://ficc.gcdev.co"
    ]
  },
  "Email": {
    "SmtpHost": "smtp.zoho.com",
    "SmtpPort": "587",
    "Username": "${EMAIL_USERNAME}",
    "Password": "${EMAIL_PASSWORD}",
    "From": "${EMAIL_FROM}",
    "FromName": "اتحاد الغرف التجارية العراقية"
  },
  "Twilio": {
    "AccountSid": "${TWILIO_ACCOUNT_SID}",
    "AuthToken": "${TWILIO_AUTH_TOKEN}",
    "VerifyServiceSid": "${TWILIO_VERIFY_SERVICE_SID}"
  },
  "ZeptoMail": {
    "ApiKey": "${ZEPTOMAIL_API_KEY}",
    "From": "noreply@ficc.iq",
    "FromName": "اتحاد الغرف التجارية العراقية"
  },
  "Brevo": {
    "ApiKey": "${BREVO_API_KEY}"
  }
}
